# ===== DATABASE (PostgreSQL - Neon for Vercel) =====
# Get your free Neon database at https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ===== VERCEL BLOB (Image Storage) =====
# Get your blob token at https://vercel.com/dashboard/stores/blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxx"

# ===== TELEGRAM NOTIFICATIONS (Optional) =====
# Create a bot via https://t.me/BotFather and get your token
TELEGRAM_BOT_TOKEN=""
# Your Telegram chat ID to receive notifications
TELEGRAM_CHAT_ID=""

# ===== NEXT.JS =====
NEXT_PUBLIC_VERCEL_URL="localhost:3000"
